# Foundry project / agent
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_AGENT_NAME=contract-redline-agent
FOUNDRY_MODEL_DEPLOYMENT=gpt-4.1

# Logic App full HTTP trigger invoke URLs (include SAS token query params).
# Get from Azure Portal → Logic App → Overview → click trigger → copy HTTP POST URL.
DOWNLOAD_LOGIC_APP_URL=https://prod-XX.eastus2.logic.azure.com:443/workflows/<id>/triggers/manual/paths/invoke?api-version=2016-10-01&sp=...&sv=...&sig=...
UPLOAD_LOGIC_APP_URL=https://prod-XX.eastus2.logic.azure.com:443/workflows/<id>/triggers/manual/paths/invoke?api-version=2016-10-01&sp=...&sv=...&sig=...

# Defaults
DEFAULT_AUTHOR=Contract Review Agent
COHERENCE_CONTEXT_PARAGRAPHS=2
