# Microsoft Entra ID / Azure AD (for Microsoft Graph API)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Certificate auth (use instead of client secret when secrets are disabled by policy)
AZURE_CLIENT_CERTIFICATE_PATH=
AZURE_CLIENT_CERTIFICATE_PASSWORD=

# SharePoint Configuration (optional - can be resolved from document URL)
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# API Security
API_KEY=your-api-key-here

# Application Settings
APP_NAME=Contract Redline Tool
DEBUG=false
TEMP_DIR=/tmp/redline

# Redline Defaults
DEFAULT_AUTHOR=Contract Review Agent
